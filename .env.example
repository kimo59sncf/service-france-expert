# Service France Expert - Variables d'environnement

# Port du serveur API (optionnel, défaut: 5000)
PORT=5000

# Mot de passe pour l'interface admin (optionnel, défaut: Karim321@)
VITE_ADMIN_PASSWORD=Karim321@

# URL de base de l'API frontend (optionnel si API et frontend sur même domaine)
VITE_API_BASE_URL=

# URL de connexion PostgreSQL (optionnel si vous utilisez le storage JSON local)
# DATABASE_URL=postgresql://user:password@host:5432/database

# Environnement (development/production)
NODE_ENV=production